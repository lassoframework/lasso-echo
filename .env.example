# ── AGENT (LASSO Social Agent) — Stage 1 env ──────────────────────────────────
# Copy to .env and fill by hand. NEVER commit .env. Tokens are set by Blake only.

# Master kill switch. OFF by default. Set true to let the agent run at all.
AGENT_ENABLED=false

# Real publishing. OFF by default = DRAFT-ONLY (Approve only logs "would publish").
# Leave false until the drafts look right for days. Arm by hand.
AGENT_PUBLISH_ENABLED=false

# Approver. Only this Slack user can approve. Defaults to Blake if unset.
AGENT_APPROVER_SLACK_ID=U06EPUUCL13

# Slack control surface
AGENT_SLACK_BOT_TOKEN=          # xoxb-... bot token (set by hand)
AGENT_SLACK_CHANNEL_ID=         # the #echoclaude channel id

# Paths
AGENT_VOICE_DOC_PATH=brand_voice/lasso_voice.md
AGENT_LIBRARY_PATH=content_library
AGENT_POST_LOG_PATH=post_log.jsonl

# Meta Graph API version
AGENT_GRAPH_API_VERSION=v21.0

# ── Per-account tokens + target ids (set by hand, never logged) ───────────────
# LASSO Instagram (IG Business/Creator linked to a Page)
AGENT_LASSO_IG_TOKEN=
AGENT_LASSO_IG_USER_ID=

# LASSO Facebook Page
AGENT_LASSO_FB_TOKEN=
AGENT_LASSO_FB_PAGE_ID=

# Blake personal (see README: Graph API cannot publish to a personal FB profile)
AGENT_BLAKE_PERSONAL_TOKEN=
AGENT_BLAKE_PERSONAL_ID=

# ── Slack Socket Mode (added for the live listener) ───────────────────────────
AGENT_SLACK_APP_TOKEN=          # xapp-... app-level token, scope connections:write
AGENT_SCHEDULER_ENABLED=true    # in-process daily trigger; false if using Railway cron
AGENT_DAILY_HOUR_UTC=14         # ~10am ET, when the daily draft fires

# ── Runtime memory paths (point these at a Railway Volume, e.g. /data) ────────
AGENT_PENDING_PATH=pending_drafts.json
AGENT_POST_LOG_PATH=post_log.jsonl
# --- Tier 1 hardening (Fable 5 review). Every flag defaults OFF. ---
AGENT_IDEMPOTENT_DRAFTS_ENABLED=false  # one draft per (account, day, type); re-runs reuse, changes supersede, stale cards expire
AGENT_OPS_ALERTS_ENABLED=false         # one "ECHO ALERT:" Slack line per pipeline failure (secrets scrubbed)
AGENT_PUBLISH_CONFIRM_ENABLED=false    # Graph read-back after a real publish; permalink replied in the card thread
AGENT_TOKEN_WATCHDOG_ENABLED=false     # daily debug_token expiry check; token value never printed
AGENT_TOKEN_WARN_DAYS=7                # days before token expiry the watchdog starts alerting
# ---- Creative rotation + variety guard. Defaults OFF. ----
AGENT_ROTATION_ENABLED=false     # no-repeat window + pillar alternation + library cycling; gate-clean creatives only
AGENT_ROTATION_WINDOW_DAYS=14     # days before a served creative may repeat

# =============================================================================
# COMPLETE FLAG REFERENCE (2026-07-03 overnight stages build). Authoritative,
# self contained: every capability flag in the codebase, grouped, all code
# defaults shown explicitly (everything defaults OFF unless marked). Production
# arms flags in Railway env only; a fresh checkout is always dormant.
# =============================================================================

# ---- Core gates (Stage 1; ARMED in production via Railway) ----
AGENT_ENABLED=false                   # master switch for the daily drafter
AGENT_PUBLISH_ENABLED=false           # real Meta writes; false = draft-only everywhere
AGENT_SCHEDULER_ENABLED=true          # in-listener daily trigger (the ONE default-true flag)
AGENT_STORIES_ENABLED=false           # daily 9:16 story draft + gated publish

# ---- Tier 1 capabilities (ARMED in production) ----
AGENT_CONTENT_BRAIN_ENABLED=false     # daily post drafted from lasso_now.md
AGENT_NANO_ENABLED=false              # Gemini infographic generation (creative studio)
AGENT_HOSTING_ENABLED=false           # R2 media hosting for drafts
AGENT_CAPTION_SEO_ENABLED=false       # hook-first caption reorder (approved lines only)
AGENT_PLATFORM_VARIANTS_ENABLED=false # per-platform hashtag counts (IG 5, FB 2)
AGENT_IDEMPOTENT_DRAFTS_ENABLED=false # one draft per account/day/type + supersede
AGENT_OPS_ALERTS_ENABLED=false        # ECHO ALERT lines to Slack
AGENT_PUBLISH_CONFIRM_ENABLED=false   # post-publish existence read + LIVE reply
AGENT_TOKEN_WATCHDOG_ENABLED=false    # token expiry warnings (AGENT_TOKEN_WARN_DAYS=10)

# ---- Content sources and campaigns ----
AGENT_KNOWLEDGE_ENABLED=false         # knowledge brain as gated source (USE stats only)
AGENT_SOCIAL_PROOF_ENABLED=false      # weekly verified proof card (AGENT_SOCIAL_PROOF_DAY=wed)
AGENT_SUMMIT_CAMPAIGN_ENABLED=false   # weekly summit post (auto-stops after 2026-11-08)
AGENT_BOOK_CAMPAIGN_ENABLED=false     # THE FULL GYM launch: queue verbatim, then angles
AGENT_DOC_INTAKE_ENABLED=false        # PDF -> N approval-held draft posts

# ---- Creative selection and quality ----
AGENT_ROTATION_ENABLED=false          # no-repeat window + pillar/archetype/set variety
AGENT_ROTATION_WINDOW_DAYS=14
AGENT_RUNWAY_ENABLED=false            # days-of-content line + low-runway ask
AGENT_RUNWAY_ALERT_DAYS=7
AGENT_OCR_CHECK_ENABLED=false         # headline transcription check (warning, never block)
AGENT_SPEND_CAP_ENABLED=false         # daily Gemini call cap -> library-only fallback
AGENT_GEMINI_DAILY_CAP=40
AGENT_STORY_PREMADE_ENABLED=false     # prefer premade *_story renders over re-render

# ---- DAM (asset safety) ----
AGENT_CONSENT_GUARD_ENABLED=false     # people need consent=granted; unknown = excluded (tag library FIRST)
AGENT_AUTOTAG_ENABLED=false           # Gemini vision tags per new asset (counts against spend cap)

# ---- Client intake and onboarding ----
AGENT_INTAKE_ENABLED=false            # texted-link upload page + in-listener ingest
AGENT_INTAKE_POLL_MINUTES=5
AGENT_INTAKE_MAX_FILE_MB=100
AGENT_INTAKE_MAX_REQUEST_MB=300
AGENT_INTAKE_RATE_PER_MINUTE=10
# AGENT_INTAKE_TOKEN_<CLIENTKEY>=     # one long random token per client, both services
AGENT_CONNECT_ENABLED=false           # /connect Facebook Login for Business page
AGENT_CONNECT_TOKENS_ENABLED=false    # kv page tokens into account resolution (env always wins)
AGENT_CONNECT_BASE_URL=               # public https base for the OAuth redirect
AGENT_CONNECT_PORT=8090
META_APP_ID=                          # Meta app id (by hand)
META_APP_SECRET=                      # Meta app secret (by hand, never logged)

# ---- Reporting and the review loop ----
AGENT_REPORTING_ENABLED=false         # daily Graph snapshots (views, never impressions)
AGENT_GRADE_ENABLED=false             # Social Grade A to F + grade-card CLI
AGENT_MONTHLY_REVIEW_ENABLED=false    # the 30 day loop: digest + white label PDF
AGENT_DIGEST_ENABLED=false            # one evening summary line (AGENT_DIGEST_HOUR_UTC=23)
AGENT_BRAIN_PROPOSALS_ENABLED=false   # nightly read-only proposal note (digest hour + 1)

# ---- Trust ladder (per account, never global) ----
AGENT_TRUST_LADDER_ENABLED=false      # double gate for level data (from block 1)
AGENT_TRUST_DRYRUN=false              # mark would-auto-publish on cards; still needs the tap
AGENT_TRUST_AUTOPUBLISH=false         # calendar-routine level 1+ only; startup warning when armed

# ---- Ops ----
AGENT_BACKUP_ENABLED=false            # nightly sqlite snapshot to R2 (14 day retention)
AGENT_BACKUP_HOUR_UTC=2
AGENT_BACKUP_RETENTION_DAYS=14
AGENT_COMMENTS_ENABLED=false          # two-tier comment engine, everything held for approval

# ---- Opus Clip ingest ----
AGENT_OPUS_ENABLED=false              # pull finished clips -> Reel drafts
AGENT_OPUS_POLL_ENABLED=false         # listener poll (needs AGENT_OPUS_ENABLED too)
AGENT_OPUS_POLL_MINUTES=60
OPUS_API_KEY=                         # Bearer key from the OpusClip dashboard
AGENT_OPUS_ORG_ID=
AGENT_OPUS_PROJECT_IDS=               # comma separated; pin the dashboard projects
AGENT_OPUS_COLLECTION_IDS=
